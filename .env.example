# ============================================================================
# BeeClaw 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================================================

# ── LLM 配置 ────────────────────────────────────────────────────────────────
# LLM API 基础 URL (默认: http://localhost:11434, 兼容 OpenAI / Ollama)
BEECLAW_LLM_BASE_URL=http://localhost:11434

# LLM API Key (本地 Ollama 不需要)
BEECLAW_LLM_API_KEY=no-key

# 模型分层配置
BEECLAW_LOCAL_MODEL=qwen2.5:7b        # 本地免费模型 (50-60% Agent)
BEECLAW_CHEAP_MODEL=qwen2.5:7b        # 便宜云模型 (30-40% Agent)
BEECLAW_STRONG_MODEL=qwen2.5:72b      # 强模型 (5-10% Agent)

# ── Server 配置 ─────────────────────────────────────────────────────────────
BEECLAW_PORT=3000
BEECLAW_HOST=0.0.0.0
BEECLAW_TICK_INTERVAL=30000            # Tick 间隔 (毫秒)
BEECLAW_INITIAL_AGENTS=10             # 初始 Agent 数量
BEECLAW_DB_PATH=                       # SQLite 数据库路径 (留空使用内存)
BEECLAW_SEED_EVENT=                    # 启动时注入的种子事件
BEECLAW_SAVE_INTERVAL=5               # 每 N 个 tick 保存一次

# ── 数据库配置 ─────────────────────────────────────────────────────────────
# 数据库驱动: sqlite (默认) | postgres
# BEECLAW_DB_DRIVER=sqlite

# PostgreSQL 配置 (仅 BEECLAW_DB_DRIVER=postgres 时生效)
# POSTGRES_USER=beeclaw                # PostgreSQL 用户名
# POSTGRES_PASSWORD=beeclaw            # PostgreSQL 密码 (生产环境请使用强密码!)
# POSTGRES_DB=beeclaw                  # PostgreSQL 数据库名
# POSTGRES_PORT=5432                   # PostgreSQL 端口映射 (宿主机端口)
# DATABASE_URL=postgresql://beeclaw:beeclaw@localhost:5432/beeclaw  # 完整连接字符串 (手动部署时使用)

# ── 安全与访问控制 ─────────────────────────────────────────────────────────
# BEECLAW_API_KEY=                     # API 认证 Bearer token (留空=不启用认证, 开发模式)
# BEECLAW_CORS_ORIGINS=                # 允许的 CORS 域名 (逗号分隔, 留空=允许所有, 开发模式)
                                       # 例如: https://dashboard.beeclaw.com,https://admin.beeclaw.com
BEECLAW_RATE_LIMIT=100                # 每分钟最大请求数 (/health 和 /metrics/prometheus 不受限)

# ── 日志 ────────────────────────────────────────────────────────────────────
BEECLAW_LOG_LEVEL=info                 # debug | info | warn | error
NODE_ENV=development                   # development | production (production 启用 JSON 日志)
